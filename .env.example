# Firebase Web config (Vite env variables)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# For running the admin seed script (use a service account JSON)
# Option A: path to service account JSON file
SERVICE_ACCOUNT_FILE=./serviceAccountKey.json

# Option B: raw JSON (useful in CI) - set the full JSON string
# SERVICE_ACCOUNT_JSON={...}

# Admin defaults for seeding
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD is optional; default: Admin@123456
ADMIN_PASSWORD=
ADMIN_NAME=Administrator
